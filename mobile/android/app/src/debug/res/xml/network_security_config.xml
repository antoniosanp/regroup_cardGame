<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only: Android 9+ (API 28+) blocks plain HTTP/WS (cleartext) traffic by
  default. The dev backend runs on plain http://, not https://, so without this
  api_client.dart's POST /api/players and the STOMP WebSocket connect would
  fail. Debug builds permit cleartext to ANY host so an in-app "Server address"
  pointed at a LAN IP (e.g. 192.168.x.x:8080) works without editing this file
  per address. This applies to debug builds only (src/debug/res/xml) — release
  builds have no cleartext exception and must talk to an https backend.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
